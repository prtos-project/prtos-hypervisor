#!/bin/sh

case "$1" in
    start)
        echo "=== PRTOS System Partition ==="
        # Create /dev/net/tun for TAP networking
        mkdir -p /dev/net
        mknod /dev/net/tun c 10 200 2>/dev/null
        /usr/bin/prtos_manager &
        /usr/bin/virtio_backend &
        sleep 2
        # Configure TAP IP addresses for System<->Guest p2p networking
        for i in 0 1 2; do
            if [ -d "/sys/class/net/tap$i" ]; then
                ip addr add 10.0.$((i + 1)).1/24 dev tap$i 2>/dev/null
                ip link set tap$i up 2>/dev/null
                echo "  tap$i: 10.0.$((i + 1)).1/24"
            fi
        done
        ;;
    stop)
        killall virtio_backend 2>/dev/null
        killall prtos_manager 2>/dev/null
        ;;
    *)
        echo "Usage: $0 {start|stop}"
        exit 1
        ;;
esac
