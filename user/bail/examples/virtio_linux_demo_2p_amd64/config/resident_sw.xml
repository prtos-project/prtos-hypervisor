<!--
  PRTOS Configuration: Virtio Linux Demo (amd64) - 2 SMP Linux Partitions
  UART + VGA Dual Console

  Architecture (3-layer):
    L0: Host Linux (Ubuntu 24.04) + QEMU (x86_64, KVM)
    L1: PRTOS Type-1 Hypervisor
    L2: System Partition (Virtio Backend) + Guest Partition (Virtio Frontend)

  Memory layout (all within first 1GB for PRTOS identity map):
    PRTOS Hypervisor:      8MB  (0x1000000 - 0x17fffff)
    Partition 0 (System):  GPA 0x6000000,  128MB, 2 vCPU on pCPU 0-1 (VMX hw-virt)
    Partition 1 (Guest):   GPA 0xE000000,  128MB, 2 vCPU on pCPU 2-3 (VMX hw-virt)
    Shared Memory:
      Virtio_Net0:  1MB   @ 0x16000000  (virtio-net bridge)
      Virtio_Net1:  1MB   @ 0x16100000  (virtio-net NAT)
      Virtio_Net2:  1MB   @ 0x16200000  (virtio-net p2p)
      Virtio_Blk:   2MB   @ 0x16300000  (virtio-blk file-backed)
      Virtio_Con:   256KB @ 0x16500000  (virtio-console)

  CPU Assignment (SMP):
    pCPU 0 -> System Partition vCPU 0
    pCPU 1 -> System Partition vCPU 1
    pCPU 2 -> Guest Partition  vCPU 0
    pCPU 3 -> Guest Partition  vCPU 1

  Console Assignment:
    System Partition -> UART (serial stdio, SSH terminal)
    Guest Partition  -> VGA  (VNC :1, remote VGA display)

  Virtio Devices (Backend in System, Frontend in Guest):
    virtio-net0:     bridge mode     (IPVI 0, vector 32)
    virtio-net1:     NAT mode        (IPVI 1, vector 33)
    virtio-net2:     p2p mode        (IPVI 2, vector 34)
    virtio-blk:      file-backed     (IPVI 3, vector 35)
    virtio-console:  character ring  (IPVI 4, vector 36)

  Doorbell IRQ (Guest -> System):
    IPVI 0: net0  (Guest src=1 -> System dst=0)
    IPVI 1: net1  (Guest src=1 -> System dst=0)
    IPVI 2: net2  (Guest src=1 -> System dst=0)
    IPVI 3: blk   (Guest src=1 -> System dst=0)
    IPVI 4: con   (Guest src=1 -> System dst=0)
    IPVI 5: System -> Guest completion doorbell

  Scheduler: 4 pCPUs, dedicated mapping, 10ms major frame.
-->
<SystemDescription xmlns="http://www.prtos.org/prtos-1.x" version="1.0.0" name="virtio_linux_demo_2p_amd64">
    <HwDescription>
        <MemoryLayout>
            <Region type="ram" start="0x0" size="512MB" />
        </MemoryLayout>
        <ProcessorTable>
            <Processor id="0">
                <CyclicPlanTable>
                    <Plan id="0" majorFrame="10ms">
                        <Slot id="0" start="0ms" duration="10ms" partitionId="0" vCpuId="0"/>
                    </Plan>
                </CyclicPlanTable>
            </Processor>
            <Processor id="1">
                <CyclicPlanTable>
                    <Plan id="0" majorFrame="10ms">
                        <Slot id="0" start="0ms" duration="10ms" partitionId="0" vCpuId="1"/>
                    </Plan>
                </CyclicPlanTable>
            </Processor>
            <Processor id="2">
                <CyclicPlanTable>
                    <Plan id="0" majorFrame="10ms">
                        <Slot id="0" start="0ms" duration="10ms" partitionId="1" vCpuId="0"/>
                    </Plan>
                </CyclicPlanTable>
            </Processor>
            <Processor id="3">
                <CyclicPlanTable>
                    <Plan id="0" majorFrame="10ms">
                        <Slot id="0" start="0ms" duration="10ms" partitionId="1" vCpuId="1"/>
                    </Plan>
                </CyclicPlanTable>
            </Processor>
        </ProcessorTable>
        <Devices>
            <Uart id="0" baudRate="115200" name="Uart" />
            <Vga name="Vga" />
        </Devices>
    </HwDescription>

    <PRTOSHypervisor console="Uart">
        <PhysicalMemoryArea size="8MB" />
    </PRTOSHypervisor>

    <PartitionTable>
        <Partition id="0" name="System" flags="system" console="Uart" noVCpus="2">
            <PhysicalMemoryAreas>
                <Area start="0x6000000" size="128MB" />
                <Area start="0x16000000" size="1MB"   flags="shared"/>
                <Area start="0x16100000" size="1MB"   flags="shared"/>
                <Area start="0x16200000" size="1MB"   flags="shared"/>
                <Area start="0x16300000" size="2MB"   flags="shared"/>
                <Area start="0x16500000" size="256KB"  flags="shared"/>
            </PhysicalMemoryAreas>
            <HwResources>
                <IoPorts>
                    <Range base="0xCF8" noPorts="4"/>
                    <Range base="0xCFC" noPorts="4"/>
                </IoPorts>
            </HwResources>
            <PortTable>
                <Port type="sampling" direction="destination" name="GuestToSystem"/>
                <Port type="sampling" direction="source" name="SystemToGuest"/>
            </PortTable>
        </Partition>

        <Partition id="1" name="Guest" console="Vga" noVCpus="2">
            <PhysicalMemoryAreas>
                <Area start="0xE000000" size="128MB" />
                <Area start="0x16000000" size="1MB"   flags="shared flag3"/>
                <Area start="0x16100000" size="1MB"   flags="shared flag3"/>
                <Area start="0x16200000" size="1MB"   flags="shared flag3"/>
                <Area start="0x16300000" size="2MB"   flags="shared flag3"/>
                <Area start="0x16500000" size="256KB"  flags="shared flag3"/>
            </PhysicalMemoryAreas>
            <PortTable>
                <Port type="sampling" direction="source" name="GuestToSystem"/>
                <Port type="sampling" direction="destination" name="SystemToGuest"/>
            </PortTable>
        </Partition>
    </PartitionTable>

    <Channels>
        <Ipvi id="0" sourceId="1" destinationId="0" />
        <Ipvi id="1" sourceId="1" destinationId="0" />
        <Ipvi id="2" sourceId="1" destinationId="0" />
        <Ipvi id="3" sourceId="1" destinationId="0" />
        <Ipvi id="4" sourceId="1" destinationId="0" />
        <Ipvi id="5" sourceId="0" destinationId="1" />

        <SamplingChannel maxMessageLength="8B">
            <Source partitionId="1" portName="GuestToSystem"/>
            <Destination partitionId="0" portName="GuestToSystem"/>
        </SamplingChannel>
        <SamplingChannel maxMessageLength="8B">
            <Source partitionId="0" portName="SystemToGuest"/>
            <Destination partitionId="1" portName="SystemToGuest"/>
        </SamplingChannel>
    </Channels>

</SystemDescription>
