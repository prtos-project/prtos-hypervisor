#!/bin/sh
#
# S99virtio_guest - Guest Partition init script.
# Spawns getty on ttyS1 (COM2) for host telnet at port 4321.
# Spawns getty on /dev/hvc0 (virtio console) for System telnet at port 4321.
#

case "$1" in
    start)
        echo "=== PRTOS Guest Partition ==="
        echo "Console: tty0 (VGA) + ttyS1 (COM2 -> telnet :4321)"
        echo "CPUs: $(nproc), Kernel: $(uname -r)"

        # Set ttyS1 (COM2) to polling mode (irq=0).
        # PRTOS doesn't route IRQ3 to Guest, so 8250 driver needs
        # timer-based polling instead of interrupt-driven I/O.
        if [ -c /dev/ttyS1 ]; then
            /opt/set_serial_poll /dev/ttyS1 2>/dev/null
            # Send a marker to verify COM2 output works
            echo "COM2_READY" > /dev/ttyS1 2>/dev/null
            /sbin/getty -L ttyS1 115200 vt100 &
            echo "getty on ttyS1 started (host telnet localhost 4321)"
        fi

        # Start Virtio Frontend daemon (bridges shared memory to /dev/nbd0, /dev/hvc0, tap*)
        if [ -x /usr/bin/virtio_frontend ]; then
            echo "Starting Virtio Frontend daemon..."
            /usr/bin/virtio_frontend --all &
            sleep 2
            # Create /dev/vda symlink to /dev/nbd0 for compatibility
            if [ -b /dev/nbd0 ]; then
                ln -sf /dev/nbd0 /dev/vda 2>/dev/null
                echo "Virtio-Blk: /dev/vda -> /dev/nbd0"
            fi
            # Configure TAP IP addresses for Guest<->System networking
            for i in 0 1 2; do
                if [ -d "/sys/class/net/tap$i" ]; then
                    ip addr add 10.0.$((i + 1)).2/24 dev tap$i 2>/dev/null
                    ip link set tap$i up 2>/dev/null
                    echo "  tap$i: 10.0.$((i + 1)).2/24"
                fi
            done
            # Wait for virtio_frontend to create /dev/hvc0 (PTY),
            # then spawn getty for the virtio console TCP bridge.
            (
                for _w in $(seq 1 30); do
                    if [ -e /dev/hvc0 ]; then
                        /sbin/getty -L hvc0 115200 vt100 &
                        echo "getty on /dev/hvc0 started (System telnet 127.0.0.1 4321)"
                        break
                    fi
                    sleep 1
                done
            ) &
        fi
        ;;
    stop)
        ;;
    *)
        echo "Usage: $0 {start|stop}"
        exit 1
        ;;
esac
