#!/bin/sh
#
# S99virtio_guest - Guest Partition init script.
# Spawns getty on ttyS1 (COM2) for telnet login at port 4321.
#

case "$1" in
    start)
        echo "=== PRTOS Guest Partition ==="
        echo "Console: tty0 (VGA) + ttyS1 (COM2 -> telnet :4321)"
        echo "CPUs: $(nproc), Kernel: $(uname -r)"

        # Set ttyS1 (COM2) to polling mode (irq=0).
        # PRTOS doesn't route IRQ3 to Guest, so 8250 driver needs
        # timer-based polling instead of interrupt-driven I/O.
        if [ -c /dev/ttyS1 ]; then
            /opt/set_serial_poll /dev/ttyS1 2>/dev/null
            /sbin/getty -L ttyS1 115200 vt100 &
            echo "getty on ttyS1 started (telnet localhost 4321)"
        fi
        ;;
    stop)
        ;;
    *)
        echo "Usage: $0 {start|stop}"
        exit 1
        ;;
esac
