<SystemDescription xmlns="http://www.prtos.org/prtos-1.x" version="1.0.0" name="freertos_hwvirt_loongarch64">
    <HwDescription>
        <MemoryLayout>
            <!-- Cover UART MMIO region and main RAM -->
            <Region type="ram" start="0x0" size="512MB" />
            <Region type="ram" start="0x80000000" size="512MB" />
        </MemoryLayout>
        <ProcessorTable>
            <Processor id="0">
                <CyclicPlanTable>
                    <Plan id="0" majorFrame="2ms">
                        <Slot id="0" start="0ms" duration="1ms" partitionId="0" />
                    </Plan>
                </CyclicPlanTable>
            </Processor>
        </ProcessorTable>
        <Devices>
            <Uart id="0" baudRate="115200" name="Uart" />
        </Devices>
    </HwDescription>

    <PRTOSHypervisor console="Uart">
        <PhysicalMemoryArea size="32MB" />
    </PRTOSHypervisor>

    <PartitionTable>
        <Partition id="0" name="FreeRTOS_Native" flags="system" hw_virt="true" console="Uart">
            <PhysicalMemoryAreas>
                <!-- Native FreeRTOS code and data -->
                <Area start="0x0A000000" size="64MB" />
                <!-- UART device pass-through (16550 at 0x1FE001E0) -->
                <Area start="0x1FE00000" size="4KB" flags="uncacheable" />
            </PhysicalMemoryAreas>
        </Partition>
    </PartitionTable>
</SystemDescription>
