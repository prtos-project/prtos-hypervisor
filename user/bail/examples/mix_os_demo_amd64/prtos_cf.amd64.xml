<!--
  Mixed-OS Demo (amd64): Linux (hw-virt VMX) + FreeRTOS (para-virt)

  Memory layout:
    Partition 0 (Linux):    GPA 0x6000000, 256MB, 1 vCPU on pCPU 0 (VMX hw-virt)
    Partition 1 (FreeRTOS): 0x4000000, 2MB, 1 vCPU on pCPU 1 (para-virt)

  Scheduler: Each pCPU runs one vCPU of one partition.
    pCPU 0: Linux vCPU 0 (50ms slot)
    pCPU 1: FreeRTOS vCPU 0 (1ms slot, real-time)
-->
<SystemDescription xmlns="http://www.prtos.org/prtos-1.x" version="1.0.0" name="mix_os_demo_amd64">
    <HwDescription>
        <MemoryLayout>
            <Region type="ram" start="0x0" size="512MB" />
        </MemoryLayout>
        <ProcessorTable>
            <Processor id="0">
                <CyclicPlanTable>
                    <Plan id="0" majorFrame="100ms">
                        <Slot id="0" start="0ms" duration="50ms" partitionId="0" vCpuId="0"/>
                    </Plan>
                </CyclicPlanTable>
            </Processor>
            <Processor id="1">
                <CyclicPlanTable>
                    <Plan id="0" majorFrame="2ms">
                        <Slot id="0" start="0ms" duration="1ms" partitionId="1" vCpuId="0"/>
                    </Plan>
                </CyclicPlanTable>
            </Processor>
        </ProcessorTable>
        <Devices>
            <Uart id="0" baudRate="115200" name="Uart" />
        </Devices>
    </HwDescription>

    <PRTOSHypervisor console="Uart">
        <PhysicalMemoryArea size="8MB" />
    </PRTOSHypervisor>

    <PartitionTable>
        <Partition id="0" name="Linux" flags="system" console="Uart">
            <PhysicalMemoryAreas>
                <Area start="0x6000000" size="256MB" />
            </PhysicalMemoryAreas>
        </Partition>
        <Partition id="1" name="FreeRTOS" flags="system" console="Uart">
            <PhysicalMemoryAreas>
                <Area start="0x4000000" size="2MB" mappedAt="0x4000000" />
            </PhysicalMemoryAreas>
        </Partition>
    </PartitionTable>
</SystemDescription>
