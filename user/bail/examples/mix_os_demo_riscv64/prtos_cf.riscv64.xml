<!--
  Mixed-OS Demo (RISC-V 64): Linux (3 vCPUs) + FreeRTOS para-virt (1 vCPU)

  Memory layout:
    Partition 0 (Linux):    IPA 0x90000000, 256MB, 3 vCPUs on pCPU 0-2 (hw-virt)
    Partition 1 (FreeRTOS): IPA 0x88000000, 2MB, 1 vCPU on pCPU 3 (para-virt)

  Scheduler: Each pCPU runs one vCPU of one partition.
    pCPU 0: Linux vCPU 0 (50ms slot)
    pCPU 1: Linux vCPU 1 (50ms slot)
    pCPU 2: Linux vCPU 2 (50ms slot)
    pCPU 3: FreeRTOS vCPU 0 (1ms slot, real-time)
-->
<SystemDescription xmlns="http://www.prtos.org/prtos-1.x" version="1.0.0" name="mix_os_demo_riscv64">
    <HwDescription>
        <MemoryLayout>
            <Region type="ram" start="0x0" size="512MB" />
            <Region type="ram" start="0x80000000" size="1024MB" />
        </MemoryLayout>
        <ProcessorTable>
            <Processor id="0">
                <CyclicPlanTable>
                    <Plan id="0" majorFrame="100ms">
                        <Slot id="0" start="0ms" duration="50ms" partitionId="0" vCpuId="0"/>
                    </Plan>
                </CyclicPlanTable>
            </Processor>
            <Processor id="1">
                <CyclicPlanTable>
                    <Plan id="0" majorFrame="100ms">
                        <Slot id="0" start="0ms" duration="50ms" partitionId="0" vCpuId="1"/>
                    </Plan>
                </CyclicPlanTable>
            </Processor>
            <Processor id="2">
                <CyclicPlanTable>
                    <Plan id="0" majorFrame="100ms">
                        <Slot id="0" start="0ms" duration="50ms" partitionId="0" vCpuId="2"/>
                    </Plan>
                </CyclicPlanTable>
            </Processor>
            <Processor id="3">
                <CyclicPlanTable>
                    <Plan id="0" majorFrame="2ms">
                        <Slot id="0" start="0ms" duration="1ms" partitionId="1" vCpuId="0"/>
                    </Plan>
                </CyclicPlanTable>
            </Processor>
        </ProcessorTable>
        <Devices>
            <Uart id="0" baudRate="115200" name="Uart" />
        </Devices>
    </HwDescription>

    <PRTOSHypervisor console="Uart">
        <PhysicalMemoryArea size="64MB" />
    </PRTOSHypervisor>

    <PartitionTable>
        <Partition id="0" name="Linux_HMI" flags="system" console="Uart" noVCpus="3">
            <PhysicalMemoryAreas>
                <Area start="0x90000000" size="256MB" />
                <!-- UART device pass-through (16550 at 0x10000000) -->
                <Area start="0x10000000" size="4KB" />
            </PhysicalMemoryAreas>
        </Partition>
        <Partition id="1" name="FreeRTOS_RTOS" flags="system" console="Uart">
            <PhysicalMemoryAreas>
                <Area start="0x88000000" size="2MB" />
            </PhysicalMemoryAreas>
        </Partition>
    </PartitionTable>
</SystemDescription>
