/*
 * FILE: prtos.lds.in
 *
 * RISC-V 64-bit linker script for PRTOS hypervisor
 *
 * www.prtos.org
 */

#include <config.h>

OUTPUT_FORMAT("elf64-littleriscv", "elf64-littleriscv", "elf64-littleriscv")
OUTPUT_ARCH("riscv")
ENTRY(start)

/* RISC-V: identity mapped, no virtual offset */
PHYSOFFSET = 0;

SECTIONS
{
    . = CONFIG_PRTOS_LOAD_ADDR;
    _sprtos = .;

    _sboot = .;
    .boot_text ALIGN(0x1000) : {
        _stext = .;
        *(.boot.text)
        _etext_boot = .;
    }
    .boot_data : {
        *(.boot.data)
    }
    _eboot = .;

    .spbl ALIGN(0x1000) : {
        _spbl = .;
        *(.pbl)
        _epbl = .;
    }
    .prtos_hdr ALIGN(0x1000) : {
        *(.prtos_hdr)
    }

    .vboot ALIGN(0x1000) : {
        _svboot = .;
        *(.vboot.text)
        *(.vboot.data)
        _evboot = .;
    }

    .text ALIGN(0x1000) : {
        _sinittext = .;
        *(.text)
        _einittext = .;
        . = ALIGN(8);
        _sdevice = .;
        *(.dev.info)
        _edevice = .;
    }

    .rsv_hwirqs ALIGN(8) : {
        rsv_hw_irqs = .;
        end_rsv_hw_irqs = .;
    }

    .rsv_ioports ALIGN(8) : {
        rsv_io_ports = .;
        *(.rsv_ioports)
        end_rsv_io_ports = .;
    }

    .rsv_physpages ALIGN(8) : {
        rsv_phys_pages = .;
        *(.rsv_physpages)
        end_rsv_phys_pages = .;
    }

    .rodata ALIGN(0x1000) : {
        _srodata = .;
        hypercalls_table = .;
        *(.hypercallstab)
        hypercall_flags_table = .;
        *(.hypercallflagstab)

        . = ALIGN(8);
        exception_table = .;
        *(.exptable)
        QUAD(0);
        QUAD(0);

        . = ALIGN(8);
        __gp_ex_table = .;
        *(.gp_ex_tab)
        QUAD(0);

        . = ALIGN(8);
        kdev_table = .;
        *(.kdevtab)
        QUAD(0);
        . = ALIGN(8);

        kdev_setup = .;
        *(.kdevsetup)
        QUAD(0);

        . = ALIGN(8);
        object_setup_table = .;
        *(.objsetuptab)
        QUAD(0);

        . = ALIGN(8);
        *(.rodata)
        *(.rodata.*)
        _erodata = .;
    }

    .build_info ALIGN(8) : {
        build_info = .;
        *(.kbuild_info)
        *(.build_info)
        BYTE(0);
    }

    . = ALIGN(128);
    .data ALIGN(8) : {
        _sdata = .;
        *(.data.page_aligned)
        . = ALIGN(8);
        *(.vboot.data)
        *(.data)

        _edata = .;
        sys_reset_counter = .;
        QUAD(0);
        reset_status_init = .;
        QUAD(0);
        _cpdata = .;
        QUAD(0);
    }

    .bss ALIGN(0x1000) : {
        _sbss = .;
        *(COMMON)
        *(.bss)
        . = ALIGN(8);
        _ebss = .;
    }

    _eprtos = .;

    . = ALIGN(0x1000);
    prtos_conf_table = .;
    phys_prtos_conf_table = . + PHYSOFFSET;

    /DISCARD/ : {
        *(.note)
        *(.comment*)
        *(.eh_frame)
    }
}
